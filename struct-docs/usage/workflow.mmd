flowchart TD
    %% ============================================
    %% Struct Agent Team Workflow (Phase 1: Brief)
    %% ============================================

    subgraph User["사용자"]
        direction TB
        Call["/struct-think<br>/struct-write<br>/struct-solve<br>/struct-express<br>/struct-review<br>/struct-research"]
    end

    subgraph Skills["Skills Layer (SKILL.md)"]
        direction LR
        SThink["struct-think"]
        SWrite["struct-write<br>(Brief + template 옵션)"]
        SSolve["struct-solve<br>(Brief 옵션)"]
        SExpress["struct-express<br>(Brief + format)"]
        SReview["struct-review"]
        SResearch["struct-research<br>(Phase 6)"]
    end

    subgraph Orchestrator["Orchestrator (sonnet)"]
        direction TB
        O1["1. 커맨드 파싱<br>Task + Options"]
        O2["2. .struct-memory.json 로드<br>(briefs 포함)"]
        O3["3. 모드 감지<br>Collaborative vs Autonomous"]
        O4{"write / solve / express?"}
        O5["4. Brief 수집<br>purpose · audience · deliverableType"]
        O5b{"Collaborative<br>필수 3항목 확정?"}
        O5c["Brief 질문 반환<br>(Specialist 보류)"]
        O6["5. Deliverable Spec 확정<br>유형 → 템플릿 · logicPattern"]
        O7{"Prior Injection?"}
        O8["6. Prior 선택 + Read<br>## Previous Thinking Pyramid"]
        O9["7. 전문 Agent 라우팅"]
    end

    subgraph Specialists["Specialist Agents"]
        direction LR
        Think["thinking.md"]
        Write["writing.md<br>Brief + Spec + Template"]
        Solve["problem-solving.md<br>Brief framing"]
        Express["expression.md<br>Brief + format"]
        Review["review.md"]
        Research["research.md<br>Source Validation"]
    end

    subgraph Storage["Storage & Memory"]
        direction TB
        Save["struct-docs/ 저장"]
        MemUpdate[".struct-memory.json<br>briefs · previousThoughts · ..."]
    end

    Call --> Skills
    Skills --> O1
    O1 --> O2
    O2 --> O3
    O3 --> O4

    O4 -->|think / review| O9
    O4 -->|write / solve / express| O5

    O5 --> O5b
    O5b -->|No| O5c
    O5c --> Call
    O5b -->|Yes| O6

    O6 --> O7
    O7 -->|Yes| O8
    O7 -->|No| O9
    O8 --> O9

    O9 --> Think
    O9 --> Write
    O9 --> Solve
    O9 --> Express
    O9 --> Review
    O9 --> Research

    O4 -->|research| O9
    Research -.->|research-first| Write

    Think --> Save
    Write --> Save
    Solve --> Save
    Express --> Save

    Write -.->|Review Gate| ReviewGate
    Solve -.->|Review Gate| ReviewGate
    Express -.->|Review Gate| ReviewGate
    ReviewGate["Review Gate<br>Fidelity + DT1~3<br>+ DT-Submission"] --> Review
    Review --> Save
    Review -.->|submissionReady pass<br>+ split-1-5| ExpressPkg
    ExpressPkg["Express Package<br>Executive Brief 1:5"] --> Express

    subgraph ReviewDetail["Review: Phase 4 + DT-Submission"]
        direction LR
        RType["Verification Type<br>both / deliverable-quality"]
        RDel["Deliverable Quality<br>F1~F4 · DT1 · D7"]
        RSub["DT-Submission<br>ST1~ST6 · submissionReady"]
        RFix["Regeneration Directives<br>W1/W2/W3/W4"]
    end

    Review --> RType
    RType --> RDel
    RDel --> RSub
    RSub --> RFix
    RFix --> Save

    Save --> MemUpdate
    MemUpdate --> Call

    subgraph WritingDetail["Writing: Phase 3 + W4 Pipeline"]
        direction LR
        SpecW["Deliverable Spec<br>+ writingStages<br>+ submissionTarget"]
        W1["W1 Skeleton<br>골격 + Level1 매핑"]
        W2["W2 Draft<br>문장·표·논리패턴"]
        W3["W3 Audience Pass<br>Brief.audience 조율"]
        W4["W4 External Face<br>ST1~ST6 · Working 제거"]
        FinalW["submission-ready 저장<br>submissionTarget:true"]
        FinalWorking["audience-revised 저장<br>submissionTarget:false"]
    end

    Write --> SpecW
    SpecW --> W1
    W1 --> W2
    W2 --> W3
    W3 --> W4
    W4 --> FinalW
    W3 --> FinalWorking
    FinalW --> Save
    FinalWorking --> Save

    classDef user fill:#e3f2fd,stroke:#1976d2
    classDef skill fill:#f3e5f5,stroke:#7b1fa2
    classDef orch fill:#e8f5e9,stroke:#388e3c
    classDef spec fill:#fff3e0,stroke:#f57c00
    classDef store fill:#fce4ec,stroke:#c2185b
    classDef detail fill:#f5f5f5,stroke:#616161,stroke-dasharray: 5 5
    classDef hold fill:#fff9c4,stroke:#f9a825

    class Call,User user
    class SThink,SWrite,SSolve,SExpress,SReview,SResearch,Skills skill
    class O1,O2,O3,O4,O5,O5b,O6,O7,O8,O9,Orchestrator orch
    class O5c hold
    class Think,Write,Solve,Express,Review,Research,Specialists spec
    class Save,MemUpdate,Storage store
    class SpecW,W1,W2,W3,FinalW,WritingDetail,ReviewGate,RType,RDel,RFix,ReviewDetail,ExpressPkg detail
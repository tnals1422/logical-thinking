{
  "name": "bkit_sprint_list",
  "description": "List sprints with optional status filter (active|paused|archived).",
  "inputSchema": {
    "type": "object",
    "properties": {
      "status": {
        "type": "string",
        "enum": [
          "active",
          "paused",
          "archived",
          "all"
        ],
        "default": "all"
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 200,
        "default": 50
      }
    },
    "additionalProperties": false
  }
}